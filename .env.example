# Application Configuration
JWT_SECRET="your-super-secret-key-change-this-in-production"
APP_URL="http://localhost:3000"

# CalDAV Configuration
# Auth method: "oauth" for Nextcloud OAuth 2.0, "basic" for Basic Auth (Radicale/other)
CALDAV_AUTH_METHOD="basic"

# CalDAV Server URL (e.g., https://your-nextcloud-server.com/remote.php/dav/calendars)
CALDAV_SERVER_URL="https://your-caldav-server.com/caldav"

# OAuth 2.0 Configuration (Nextcloud) - Required when CALDAV_AUTH_METHOD="oauth"
OAUTH_CLIENT_ID="your-client-id"
OAUTH_CLIENT_SECRET="your-client-secret"
OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/oauth/callback"
OAUTH_AUTH_URL="https://your-nextcloud-server.com/oauth2/authorize"
OAUTH_TOKEN_URL="https://your-nextcloud-server.com/oauth2/token"

# Basic Auth Encryption Key - Required when CALDAV_AUTH_METHOD="basic"
# Must be exactly 32 bytes for AES-256
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="your-32-byte-base64-encryption-key-here"

# Optional: Gemni AI API Key
GEMINI_API_KEY="your-gemini-api-key"
